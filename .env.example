# =====================================================
# ULP Suite — Environment Variables
# =====================================================
# Setup:
#   1. cp .env.example .env
#   2. Set JWT_SECRET (see below)
#   3. Set ADMIN_PASSWORD to something strong
#   4. docker compose up -d --build
#   5. Open http://localhost:3000
# =====================================================

# ─── Authentication (REQUIRED) ──────────────────────
# Generate a random secret: openssl rand -hex 32
# SECURITY: The app refuses to start if this is unset.
JWT_SECRET=change-me-run-openssl-rand-hex-32

NEXTAUTH_URL=http://localhost:3000

# Default admin account created on first startup (if no users exist).
# IMPORTANT: Change this before running for the first time.
# The app logs a loud warning if you leave it as 'admin'.
ADMIN_EMAIL=admin@ulpsuite.local
ADMIN_PASSWORD=admin

# ─── ClickHouse ─────────────────────────────────────
# The ClickHouse host/user/db are fixed by docker-compose.yml and do NOT
# need to be set here for the standard Docker Compose deployment.
# Leave CLICKHOUSE_PASSWORD blank — the ClickHouse user config hardcodes
# an empty password for the internal Docker network.  Setting a password
# here will break all ClickHouse queries.
#
# CLICKHOUSE_USER=default   (set automatically)
# CLICKHOUSE_DB=ulp         (set automatically)
# CLICKHOUSE_PASSWORD=      (must stay empty — see above)
