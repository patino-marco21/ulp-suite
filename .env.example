# =====================================================
# ULP Suite — Environment Variables
# =====================================================
# Setup:
#   1. cp .env.example .env
#   2. Set JWT_SECRET (see below)
#   3. Set ADMIN_PASSWORD to something strong
#   4. docker compose up -d --build
#   5. Open http://localhost:3000
# =====================================================

# ─── Authentication (REQUIRED) ──────────────────────
# Generate a random secret: openssl rand -hex 32
# SECURITY: The app refuses to start if this is unset.
JWT_SECRET=change-me-run-openssl-rand-hex-32

NEXTAUTH_URL=http://localhost:3000

# Default admin account created on first startup (if no users exist).
# IMPORTANT: Change this before running for the first time.
# The app logs a loud warning if you leave it as 'admin'.
ADMIN_EMAIL=admin@ulpsuite.local
ADMIN_PASSWORD=admin

# ─── ClickHouse ─────────────────────────────────────
# The ClickHouse host/user/db are fixed by docker-compose.yml and do NOT
# need to be set here for the standard Docker Compose deployment.
# Leave CLICKHOUSE_PASSWORD blank — the ClickHouse user config hardcodes
# an empty password for the internal Docker network.  Setting a password
# here will break all ClickHouse queries.
#
# CLICKHOUSE_USER=default   (set automatically)
# CLICKHOUSE_DB=ulp         (set automatically)
# CLICKHOUSE_PASSWORD=      (must stay empty — see above)

# ─── ClickHouse backups → S3 (clickhouse-backup) ────
# Used ONLY by the `clickhouse-backup` compose service (profile: backup), which
# is invoked on demand / by cron — it never starts with `docker compose up`.
# Local hardlink snapshots need no config; these drive the off-host S3 copy.
# Any S3-compatible provider works. See docs/clickhouse-backup-runbook.md.
#
#   AWS S3:       leave S3_ENDPOINT blank, set S3_REGION (e.g. us-east-1)
#   Backblaze B2: S3_ENDPOINT=https://s3.us-west-002.backblazeb2.com   S3_REGION=us-west-002
#   Wasabi:       S3_ENDPOINT=https://s3.us-east-1.wasabisys.com       S3_REGION=us-east-1
#   MinIO:        S3_ENDPOINT=https://minio.example.com  + force_path_style: true
#                 in docker/clickhouse-backup/config.yml
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_ENDPOINT=
S3_REGION=us-east-1
S3_PATH=clickhouse-backups/ulpsuite

# ─── Content deduplication (scheduled) ─
# Collapses exact (url,email,password) duplicates that arrive across different
# source files / import times — see lib/content-dedup.ts. SAFE BY DEFAULT: it
# only REPORTS the exact duplicate count until you flip CONTENT_DEDUP_APPLY on.
# Run scripts/dedup-credentials-content.sh in dry-run for a detailed sample, then:
#   CONTENT_DEDUP_APPLY=true   → allow the background DELETE FROM to run
CONTENT_DEDUP_APPLY=false
# Cron cadence in hours (0 disables the scheduled job -- there is no separate
# import-time hook; scheduled ticks are the only trigger). Recommended at 168
# (weekly), not daily: each tick rebuilds the whole table via insert-select-
# rename, not a bounded incremental mutation, so it isn't cheap enough to run
# every day.
DEDUP_CRON_HOURS=168
# UTC hour (0-23) the first daily tick is anchored to — pick a genuinely low-traffic
# hour for your usage pattern. Every later tick lands on this same hour too.
DEDUP_CRON_HOUR_UTC=4
# Don't fire a (heavy) dedup mutation unless at least this many excess rows exist.
DEDUP_MIN_EXCESS=1000

# ─── Ingest tier filter (drop low-value rows BEFORE insert) ──
# Drops matching credentials at import time so they never cost storage / dedup /
# index / query compute — see lib/ingest-filter.ts. T3 is hard-dropped by default.
# Other filters remain off by default. Affects only
# NEW ingests; enabling it PERMANENTLY discards matching rows (re-import to recover).
# Tiers: T1 = US/UK/CA/AU/NZ · T2 = W.Europe/JP/KR/SG/IL/AE · T3 = RU/CN/BR/LATAM/SEA.
# Evaluated noise-first, then non-overridable HARD_DROP_TIERS, then keep, soft
# tier, and suffix drops. Untiered ('') is NEVER tier-dropped (most US/UK users
# are on @gmail/.com → untiered).
#
#   INGEST_FILTER_HARD_DROP_TIERS non-overridable tiers rejected before keep suffixes
#   INGEST_FILTER_DROP_NOISE     true/1 → drop junk URLs at ingest (same isNoiseUrl
#                                as the Declutter toggle: IP / :port / .php / localhost /
#                                single-label host / chrome:// & other non-web schemes).
#                                Dropped regardless of country — junk is junk.
#   INGEST_FILTER_KEEP_SUFFIXES  always keep these, even if their tier is dropped
#   INGEST_FILTER_DROP_TIERS     whole tiers to drop, e.g. T3  or  T2,T3
#   INGEST_FILTER_DROP_SUFFIXES  extra specific countries to drop
#
# DEFAULT — reject T3 while preserving T1, T2, and country-unknown credentials:
#   INGEST_FILTER_HARD_DROP_TIERS=T3
#   INGEST_FILTER_DROP_NOISE=true
INGEST_FILTER_HARD_DROP_TIERS=T3
#   (Hard-drop tiers are rejected inside the parser, before any further work —
#    no object build, dedup, batch, or insert cost. Soft/noise/suffix drops still
#    run post-parse.)
INGEST_FILTER_DROP_TIERS=
INGEST_FILTER_DROP_SUFFIXES=
INGEST_FILTER_KEEP_SUFFIXES=
INGEST_FILTER_DROP_NOISE=
