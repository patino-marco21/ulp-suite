# =====================================================
# ULP Credential Searcher — Environment Variables
# =====================================================
# 1. cp .env.example .env
# 2. Fill in your values
# 3. docker compose up -d --build
# =====================================================

# ─── ClickHouse ─────────────────────────────────────
# Primary data store for ULP credentials (url:login:password)
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=ulp

# ─── Authentication ─────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-32-char-string

NEXTAUTH_URL=http://localhost:3000

# Default admin account (created on first startup if no users exist)
# IMPORTANT: Change ADMIN_PASSWORD before deploying — use a strong unique password.
ADMIN_EMAIL=admin@ulp.local
ADMIN_PASSWORD=<set-a-strong-password-here>
