# Project-level npm configuration
#
# legacy-peer-deps: use npm v6 peer dep resolution (install even when peer
# dep ranges don't explicitly list the installed version).  This mirrors what
# "npm install --legacy-peer-deps" does locally and ensures "npm ci" in Docker
# succeeds without needing a separate flag.
#
# Background: many packages declare peer dep ranges like react@"^16|17|18" and
# haven't released a patch to add ^19 yet, even though they work fine at runtime.
# Strict npm v7+ peer dep checking treats this as a hard error in npm ci.
# legacy-peer-deps=true suppresses that error while keeping real dependency
# conflicts detectable.
#
legacy-peer-deps=true
