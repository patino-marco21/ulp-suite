# =====================================================
# ULP Suite — local development overrides
# =====================================================
# Use when running only infrastructure in Docker and the
# app locally with "npm run dev" / "yarn dev".
#
# Steps:
#   1. cp env.local.example .env.local
#   2. Start ClickHouse: docker compose up -d clickhouse
#   3. Run the app: yarn dev
#
# This file overrides only the host/URL so the Next.js
# dev server on your machine reaches the containers via
# localhost. All other values (JWT_SECRET, passwords,
# ADMIN_EMAIL/PASSWORD) come from your .env file.
# =====================================================

# ─── ClickHouse ──────────────────────────────────────
CLICKHOUSE_HOST=http://127.0.0.1:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=ulp

# ─── Next.js ─────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
