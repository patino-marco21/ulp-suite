# ─── Dependencies & build output ─────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.next/
out/
build/
dist/

# ─── LARGE DATA DIRECTORIES (bind-mounted volumes — NEVER copy into image) ──
# These are the main reason builds were 38+ GB and took 38 minutes.
# inbox/done/ alone can hold hundreds of GB of processed credential files.
uploads/
data/
inbox/
clickhouse-data/
mysql-data/
minio-data/

# ─── Database files ───────────────────────────────────────────────────────────
*.db
*.db-shm
*.db-wal

# ─── Git ──────────────────────────────────────────────────────────────────────
.git/
.gitignore

# ─── IDE / OS ─────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ─── Environment files ────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.npmrc

# ─── Logs & temp ──────────────────────────────────────────────────────────────
*.log
error.log
tmp/
test-data/

# ─── TypeScript build info ────────────────────────────────────────────────────
*.tsbuildinfo

# ─── Docker / docs (not needed inside image) ─────────────────────────────────
docker-compose.yml
docker-start.sh
docker-status.sh
Dockerfile
Dockerfile.setup
README.md
AUTHORS.md
LICENSE
docs/

# ─── Tests (not needed in production image) ──────────────────────────────────
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
__tests__/
coverage/
.devtasks

# ─── Superpowers plugin cache ─────────────────────────────────────────────────
.claude/
cookies.txt
