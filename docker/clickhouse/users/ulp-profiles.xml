<!-- ULP Suite — ClickHouse user-level profile defaults.
     Loaded automatically from /etc/clickhouse-server/users.d/ on startup.
     These are per-user (query-level) settings that cannot live in config.d/.  -->
<clickhouse>
    <profiles>
        <default>
            <!-- Compress HTTP responses automatically (gzip) -->
            <enable_http_compression>1</enable_http_compression>

            <!-- Async INSERT buffering — combines many small inserts into larger parts.
                 Dramatically reduces WAL pressure and merge amplification at bulk scale. -->
            <async_insert>1</async_insert>
            <async_insert_max_data_size>104857600</async_insert_max_data_size>   <!-- 100 MB -->
            <async_insert_max_query_number>1000</async_insert_max_query_number>
            <!-- Reduced from 500 ms to 100 ms: saves ~80 s per 100M-row file.
                 Each 500K-row batch (≈30 MB) is under the 100 MB flush threshold
                 so ClickHouse waits busy_timeout_ms per batch.  Shorter timeout =
                 faster bulk ingestion without losing the async-buffering benefit. -->
            <async_insert_busy_timeout_ms>100</async_insert_busy_timeout_ms>
            <async_insert_stale_timeout_ms>0</async_insert_stale_timeout_ms>     <!-- no stale eviction -->

            <!-- Allow more memory for GROUP BY and ORDER BY before spilling to disk -->
            <max_bytes_before_external_group_by>10737418240</max_bytes_before_external_group_by>
            <max_bytes_before_external_sort>10737418240</max_bytes_before_external_sort>

            <!-- Prevent runaway stats / analytics queries from blocking the server.
                 60 s matches the client-side max_execution_time in lib/clickhouse.ts.
                 The MV backfill queries override this inline (max_execution_time = 3600). -->
            <max_execution_time>60</max_execution_time>
            <timeout_overflow_mode>break</timeout_overflow_mode> <!-- return partial results -->

            <!-- Query result cache — caches SELECT results for 30 s.
                 Identical searches (same SQL + params) return instantly on repeat.
                 TTL short enough that fresh imports surface within 30 s. -->
            <use_query_cache>1</use_query_cache>
            <query_cache_ttl>30</query_cache_ttl>
        </default>
    </profiles>
</clickhouse>
