<!-- ULP Suite — ClickHouse user-level profile defaults.
     Loaded automatically from /etc/clickhouse-server/users.d/ on startup.
     These are per-user (query-level) settings that cannot live in config.d/.  -->
<clickhouse>
    <profiles>
        <default>
            <!-- Compress HTTP responses automatically (gzip) -->
            <enable_http_compression>1</enable_http_compression>

            <!-- Async INSERT buffering — combines many small inserts into larger parts.
                 Dramatically reduces WAL pressure and merge amplification at bulk scale.
                 Buffer raised from 100 MB → 256 MB: on a 32 GB machine each async
                 buffer costs more before flush, meaning fewer parts and fewer merges. -->
            <async_insert>1</async_insert>
            <async_insert_max_data_size>268435456</async_insert_max_data_size>   <!-- 256 MB -->
            <async_insert_max_query_number>1000</async_insert_max_query_number>
            <!-- Flush cadence: each 500K-row batch (≈30 MB) is well under the 256 MB
                 size threshold, so the timeout governs flush cadence.

                 async_insert_use_adaptive_busy_timeout (default 1 since 24.3) enables
                 an adaptive algorithm that starts at async_insert_busy_timeout_min_ms
                 and ramps up to async_insert_busy_timeout_max_ms as the server stays
                 busy.  Explicitly set to 1 here so the behaviour is documented and
                 not changed by future default changes.

                 Our bounds: min=50 ms (fast flush at low load / start of import),
                 max=100 ms (half the ClickHouse default of 200 ms — keeps bulk
                 import latency low on our 32 GB machine).

                 Note: async_insert_busy_timeout_ms is the legacy single-value alias;
                 using the canonical 26.x min/max names to avoid "obsolete setting"
                 warnings. -->
            <async_insert_use_adaptive_busy_timeout>1</async_insert_use_adaptive_busy_timeout>
            <async_insert_busy_timeout_min_ms>50</async_insert_busy_timeout_min_ms>
            <async_insert_busy_timeout_max_ms>100</async_insert_busy_timeout_max_ms>
            <async_insert_stale_timeout_ms>0</async_insert_stale_timeout_ms>     <!-- no stale eviction -->

            <!-- Spill-to-disk thresholds for GROUP BY / ORDER BY.
                 Raised from 10 GB → 20 GB: on 32 GB, larger intermediate aggregation
                 sets fit in RAM without disk spill, which is 5–10× faster.
                 Rule: set to ~50% of per-query max_memory_usage (left at server default). -->
            <max_bytes_before_external_group_by>21474836480</max_bytes_before_external_group_by>
            <max_bytes_before_external_sort>21474836480</max_bytes_before_external_sort>

            <!-- Raised 60 -> 3600 (2026-07-07): the app's own ClickHouse client
                 (lib/clickhouse.ts) explicitly passes max_execution_time=60 on every
                 query, so this profile default no longer bounds normal app queries --
                 it only bounds ad-hoc clickhouse-client CLI usage (scripts/, manual
                 debugging) and, critically, heavyweight ALTER TABLE ... DELETE/UPDATE
                 mutations' background per-part rewrite work. Confirmed live (and via
                 the still-open upstream ClickHouse/ClickHouse#61759) that a mutation's
                 per-part execution does NOT inherit max_execution_time from the
                 submitting query's own SETTINGS clause -- it's hard-capped by this
                 profile value regardless. At 60s, real parts in ulp.credentials
                 (recomputing 9 MATERIALIZED columns per row) failed with Code 159
                 TIMEOUT_EXCEEDED on every retry, never making progress -- see
                 lib/content-dedup.ts's bucketed-DELETE mechanism, which needs this
                 profile to allow a single part's rewrite more than 60s. -->
            <max_execution_time>3600</max_execution_time>

            <!-- Socket-level read/write timeout — separate from max_execution_time, which
                 bounds total query duration. This bounds how long the connection can go
                 quiet (no bytes moved) before ClickHouse drops it. Default is 30 s, which
                 produced "Timeout exceeded while reading from socket ... 30000 ms" failures
                 on large bulk-import inserts during the 2026-06-27 memory-pressure incident
                 — a server under load can stall mid-stream for longer than that without the
                 query itself being hung. Raised to 5 min for headroom on multi-minute imports. -->
            <receive_timeout>300</receive_timeout>
            <send_timeout>300</send_timeout>
            <!-- MUST be 'throw', not 'break': ClickHouse 26.x enforces that the query
                 result cache (use_query_cache=1 below) is incompatible with any overflow
                 mode other than 'throw'. With 'break' every exec() throws error 731
                 (QUERY_CACHE_USED_WITH_NON_THROW_OVERFLOW_MODE) and ALL DDL migrations
                 silently fail. 'throw' is also the correct UX: users get an explicit
                 error when a search times out rather than silently empty results. -->
            <timeout_overflow_mode>throw</timeout_overflow_mode>

            <!-- Query result cache — caches SELECT results for 30 s.
                 Identical searches (same SQL + params) return instantly on repeat.
                 TTL short enough that fresh imports surface within 30 s.
                 Requires timeout_overflow_mode=throw (see above).

                 Three ClickHouse 26.x query-cache compatibility overrides:

                 1. query_cache_system_table_handling=ignore: ClickHouse 26.x throws
                    error 719 if use_query_cache=1 and the query touches system.* tables.
                    'ignore' silently skips caching for system-table queries.

                 2. query_cache_nondeterministic_function_handling=ignore: ClickHouse 26.x
                    throws error 692 (QUERY_CACHE_USED_WITH_NONDETERMINISTIC_FUNCTIONS) if
                    use_query_cache=1 and the SQL contains non-deterministic functions such
                    as now(), today(), rand(), etc. app/api/stats/route.ts uses:
                      WHERE imported_at >= now() - INTERVAL 90 DAY
                    'ignore' silently skips caching for those queries instead of throwing. -->
            <use_query_cache>1</use_query_cache>
            <query_cache_ttl>30</query_cache_ttl>
            <!-- Only cache queries that took at least 200 ms to execute.
                 Prevents fast metadata queries (e.g. SELECT sum(rows) FROM
                 system.parts — completes in microseconds) from consuming a
                 cache slot.  Stats-page aggregation and search queries that
                 benefit from caching all run well over 200 ms on cold data. -->
            <query_cache_min_query_duration>200</query_cache_min_query_duration>
            <query_cache_system_table_handling>ignore</query_cache_system_table_handling>
            <query_cache_nondeterministic_function_handling>ignore</query_cache_nondeterministic_function_handling>
        </default>
    </profiles>
</clickhouse>
