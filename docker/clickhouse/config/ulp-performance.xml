<!-- ULP Suite — ClickHouse performance tuning for 100 B+ row credential tables.
     Loaded automatically from /etc/clickhouse-server/config.d/ on startup.
     All settings are safe to change without data migration.                      -->
<clickhouse>

    <!-- ── Background merge / mutation pool ──────────────────────────────── -->
    <!-- More threads = faster consolidation of small parts from bulk inserts.
         Raised from 16 → 20 for 32 GB / multi-core Ubuntu machine.
         Rule of thumb: (1–2) × CPU cores. 20 suits an 8–16 core processor. -->
    <background_pool_size>20</background_pool_size>
    <background_merges_mutations_concurrency_ratio>3</background_merges_mutations_concurrency_ratio>
    <background_merges_mutations_scheduling_policy>shortest_task_first</background_merges_mutations_scheduling_policy>

    <!-- ── Async INSERT ────────────────────────────────────────────────────── -->
    <!-- async_insert_* are user-level settings in ClickHouse 26.3+.
         See users.d/ulp-profiles.xml for the default profile overrides. -->

    <!-- ── HTTP layer ─────────────────────────────────────────────────────── -->
    <!-- enable_http_compression is a user-level setting — see users.d/ulp-profiles.xml -->
    <http_max_request_size>10737418240</http_max_request_size>           <!-- 10 GB max HTTP body -->

    <!-- ── MergeTree defaults (apply to all tables) ───────────────────────── -->
    <merge_tree>
        <!-- Raise insert-stall thresholds — default 150/300 is too low for bulk pipelines -->
        <parts_to_delay_insert>500</parts_to_delay_insert>
        <parts_to_throw_insert>1000</parts_to_throw_insert>
        <max_parts_in_total>100000</max_parts_in_total>

        <!-- Use compact (columnar-only) format for small parts; wide for large ones -->
        <min_bytes_for_wide_part>10485760</min_bytes_for_wide_part>      <!-- 10 MB -->
        <min_rows_for_wide_part>1000000</min_rows_for_wide_part>         <!-- 1 M rows -->

        <!-- How many rows are read per I/O block during compaction -->
        <merge_max_block_size>65536</merge_max_block_size>

        <!-- ── Durability (P0 #3) ───────────────────────────────────────────────
             fsync each freshly-written part AND its directory before the insert
             returns, so an unclean restart / power loss can't leave a torn or
             half-written part. This is the diagnosed original corruption vector
             (ClickHouse does NOT fsync by default — see the 2026-06 incident).
             Cost is at PART granularity (one fsync per inserted part, not per
             row), so with 500K-row batches it's negligible. -->
        <fsync_after_insert>1</fsync_after_insert>
        <fsync_part_directory>1</fsync_part_directory>
    </merge_tree>

    <!-- ── Memory ceiling ────────────────────────────────────────────────────────
         RESOLVED 2026-07-20 (see docs/superpowers/specs/2026-07-20-ingest-memory-backpressure-design.md):
         verified live that system.metrics 'MemoryTracking' (612 MB at idle) and
         the container's actual cgroup RSS (11 GB at idle, from
         /sys/fs/cgroup/memory.current) are NOT the same number — the ~10 GB gap
         is Linux page cache from reading/writing ClickHouse's data files, which
         cgroup v2 counts in memory.current but is reclaimable and outside
         MemoryTracking. mark_cache (256 MB) + uncompressed_cache (512 MB) cannot
         explain a 10 GB gap either. MemoryTracking vs. max_server_memory_usage is
         a real, independent, allocator-level ceiling, not conflated with page
         cache or those caches.

         Raised 16 GB → 18 GB on that basis: idle usage is 612 MB against either
         ceiling, so there was real headroom. 2 GB margin kept under the
         container's hard 20 GB mem_limit (docker-compose.yml) intentionally — if
         ClickHouse's own tracked usage ever did reach this ceiling, the
         alternative to OvercommitTracker gracefully killing one query is the
         kernel cgroup-OOM-killing the entire server process, the failure mode
         the 2026-06-07 fix (commit 6fced4c) was protecting against. As of this
         change, imports also proactively back off before reaching this ceiling
         (lib/clickhouse-memory-guard.ts, default threshold 75% = ~13.5 GB).

         max_server_memory_usage covers: query execution, query result cache,
         query condition cache, background merge buffers, connection overhead. -->
    <max_server_memory_usage>19327352832</max_server_memory_usage>      <!-- 18 GB -->

    <!-- ── Mark cache ─────────────────────────────────────────────────────────────
         Stores granule-to-column-file offsets.
         Actual size for this dataset: 22 278 granules × 40 columns × 16 B ≈ 14 MB.
         256 MB is still ~18× that — generous slack for fragmented parts during
         heavy imports, without the 1 GB this was previously set to (1 GB was 70×
         the measured need; shrinking reclaims headroom either model above turns out
         to be true — see the memory-ceiling note above this block).
         Monitor: SELECT value FROM system.asynchronous_metrics
                  WHERE metric IN ('MarkCacheFiles', 'MarkCacheBytes') -->
    <mark_cache_size>268435456</mark_cache_size>                        <!-- 256 MB -->

    <!-- ── Uncompressed cache ─────────────────────────────────────────────────────
         LRU cache of decompressed column blocks.
         512 MB ≈ 62 recent granules cached; still effective for repeated domain/email
         searches, just a smaller working set than the previous 1 GB (~125 granules).
         Combined with OS page cache and the query result cache, this avoids redundant
         decompression on hot columns without consuming excessive RSS. -->
    <uncompressed_cache_size>536870912</uncompressed_cache_size>        <!-- 512 MB -->
    <!-- max_bytes_before_external_group_by / external_sort are user-level query settings
         in ClickHouse 26.3 — see users.d/ulp-profiles.xml. -->

    <!-- Query resource limits (max_execution_time, timeout_overflow_mode) are user-level
         settings — see users.d/ulp-profiles.xml for the default profile overrides. -->

    <!-- ── Query result cache (ClickHouse 23.1+) ─────────────────────────────
         Stores the full result of a SELECT in memory for up to query_cache_ttl seconds.
         Subsequent identical queries return from cache without touching ClickHouse storage.
         1 GB total / 5 000 distinct entries / 4 MB per entry / 20 k rows per entry.
         Scaled up from 256 MB: on a 32 GB machine with analyst teams running
         repeated searches, a larger cache eliminates far more redundant ClickHouse work. -->
    <query_cache>
        <size_in_bytes>1073741824</size_in_bytes>    <!-- 1 GB total cache -->
        <max_entries>5000</max_entries>
        <max_entry_size_in_bytes>4194304</max_entry_size_in_bytes>  <!-- 4 MB per entry -->
        <max_entry_size_in_rows>20000</max_entry_size_in_rows>       <!-- 20 k rows per entry -->
    </query_cache>

    <!-- ── Query condition cache (ClickHouse 25.3+) ──────────────────────────
         Caches WHICH granules matched a WHERE filter (one bit per granule).
         Complementary to skip indexes: subsequent queries with the same filter
         skip granule re-evaluation entirely.  1 bit × 65 536 rows/granule ×
         22 000 granules ≈ 3 KB per filter condition — essentially free.
         1 GB ceiling: with 3 KB per condition, this holds ~341 000 distinct filter
         conditions — essentially unlimited for any realistic query pattern. -->
    <query_condition_cache>
        <size_in_bytes>1073741824</size_in_bytes>    <!-- 1 GB ceiling -->
    </query_condition_cache>

</clickhouse>
